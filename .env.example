SOLACE_BROKER_URL="tcp://localhost:55555"
SOLACE_BROKER_VPN="default"
SOLACE_BROKER_USERNAME="default"
SOLACE_BROKER_PASSWORD=""
# Required when using wss:// or tcps:// URLs:
# SOLACE_BROKER_TRUST_STORE_DIR="/etc/ssl/certs"

# SEMP management credentials — required only for broker setup/teardown scripts
# (scripts/configure-broker.sh and scripts/teardown-broker.sh).
# These are the *management* credentials, separate from the messaging credentials above.
# Find them in the Solace Cloud console: Connect → SEMP REST API → Management Username / Password.
SEMP_USERNAME=""
SEMP_PASSWORD=""
